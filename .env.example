# Manifest -- environment variables
#
# Copy this file to `.env.local` for local dev (Vite reads `.env.local` automatically).
# In Vercel, set these same keys in Project Settings > Environment Variables.
#
# All keys here are CLIENT-SAFE. Never put a Supabase service-role key in this file
# or in any VITE_ variable -- they get bundled into the browser build.

# Supabase project URL, e.g. https://abcd1234.supabase.co
VITE_SUPABASE_URL=

# Supabase publishable (anon) key. Found in Supabase dashboard > Project Settings > API.
VITE_SUPABASE_ANON_KEY=
